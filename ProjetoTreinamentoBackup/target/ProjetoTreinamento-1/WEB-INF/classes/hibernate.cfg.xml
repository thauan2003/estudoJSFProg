<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!--        <property name="hbm2ddl.auto">validate</property>     -->
        <property name="dialect">org.hibernate.dialect.MySQLDialect</property>
        <property name="hibernate.connection.provider_class">
            org.hibernate.hikaricp.internal.HikariCPConnectionProvider
        </property>
        <property name="hibernate.hikari.minimumIdle">5</property>
        <property name="hibernate.hikari.maximumPoolSize">2000</property>
        <property name="hibernate.hikari.leakDetectionThreshold">19000</property>
        <property name="hibernate.hikari.connectionTimeout">30000</property>
        <property name="hibernate.hikari.dataSourceClassName">com.mysql.jdbc.jdbc2.optional.MysqlDataSource</property>
        <property name="hibernate.hikari.dataSource.url">jdbc:mysql://localhost:3306/atenauru</property>
        <property name="hibernate.hikari.dataSource.user">root</property>
        <property name="hibernate.hikari.dataSource.password">deus</property>
        <property name="hibernate.max_fetch_depth">0</property>
        <property name="hibernate.hikari.dataSource.useSSL">false</property>

        <property name="show_sql">false</property>
        <property name="format_sql">false</property>
        <mapping class="com.Bean.Setor"/>
        <mapping class="com.Bean.Usuario"/>
        <mapping class="com.Bean.Auditoria"/>
</session-factory>
</hibernate-configuration>
